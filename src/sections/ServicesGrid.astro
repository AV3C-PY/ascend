---
import Card from '../components/ui/Card.astro';
---

<section class="py-24 md:py-32 bg-bg-base border-t border-border/50">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="max-w-[600px] mb-16 reveal">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-text-main mb-4" data-i18n-key="services.title">
        Nuestros Servicios Individuales
      </h2>
      <p class="text-text-muted">Si no necesitas un plan completo, puedes contratar servicios específicos para resolver cuellos de botella exactos.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      
      {[
        { title: "Desarrollo Web", price: 790, icon: "monitor" },
        { title: "E-commerce (Shopify)", price: 1290, icon: "shopping-bag" },
        { title: "Automatización WhatsApp", price: 490, icon: "message-circle" },
        { title: "Branding / Identidad", price: 690, icon: "pen-tool" },
        { title: "SEO Local", price: 390, icon: "map-pin" },
        { title: "Sistema de Reservas", price: 590, icon: "calendar" }
      ].map((service, i) => (
        <Card hoverEffect class="reveal flex flex-col" style={`transition-delay: ${(i % 3) * 100}ms;`}>
          <div class="flex items-start justify-between mb-6">
            <h3 class="text-lg font-bold text-text-main">{service.title}</h3>
          </div>
          
          <div class="flex-grow">
            <!-- Icon placeholder - In real app, import lucide-astro -->
            <div class="w-10 h-10 bg-bg-sec rounded-[10px] flex items-center justify-center text-text-muted mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            </div>
          </div>

          <div class="mt-auto pt-6 border-t border-border flex items-center justify-between">
            <div>
              <span class="text-xs text-text-muted block mb-1">Desde</span>
              <span class="font-bold text-text-main" data-base-price={service.price.toString()}>€{service.price}</span>
            </div>
            <a href={`/servicios/${service.title.toLowerCase().replace(/ /g, '-')}`} class="w-8 h-8 rounded-full bg-bg-sec flex items-center justify-center text-text-main hover:bg-primary hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          </div>
        </Card>
      ))}

    </div>
  </div>
</section>
