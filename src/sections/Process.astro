---
---

<section class="py-24 md:py-32 bg-bg-base overflow-hidden">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="max-w-[600px] mb-20 reveal">
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-text-main mb-6">El Proceso</h2>
      <p class="text-xl text-text-muted">Una metodología probada y sin fricciones. Desde el primer café hasta el lanzamiento.</p>
    </div>

    <div class="relative">
      <!-- Conector Lineal Desktop -->
      <div class="hidden md:block absolute top-[45px] left-0 w-full h-[2px] bg-border origin-left" id="process-line">
        <div class="h-full bg-primary origin-left scale-x-0 transition-transform duration-1000 ease-out" id="process-progress"></div>
      </div>
      
      <!-- Conector Lineal Mobile -->
      <div class="md:hidden absolute top-0 left-[45px] w-[2px] h-full bg-border origin-top">
        <div class="w-full bg-primary origin-top scale-y-0 transition-transform duration-1000 ease-out" id="process-progress-mobile"></div>
      </div>

      <div class="grid md:grid-cols-4 gap-12 md:gap-8 relative z-10">
        
        {[
          { step: "01", title: "Analizamos", desc: "Auditamos tu negocio, entendemos tus procesos y detectamos dónde la tecnología puede ahorrarte tiempo o hacerte ganar más." },
          { step: "02", title: "Diseñamos", desc: "Creamos la estructura y el diseño visual. Nada avanza a desarrollo sin que te encante cómo se ve." },
          { step: "03", title: "Desarrollamos", desc: "Escribimos código limpio y configuramos las automatizaciones. Cero plantillas lentas." },
          { step: "04", title: "Lanzamos", desc: "Desplegamos tu nueva plataforma al mundo, con SEO configurado y herramientas de análisis listas." }
        ].map((item, i) => (
          <div class="relative flex md:flex-col gap-6 md:gap-8 reveal" style={`transition-delay: ${i * 150}ms;`}>
            <div class="w-[90px] h-[90px] rounded-full bg-bg-base border-2 border-border flex items-center justify-center flex-shrink-0 shadow-[0_8px_16px_rgba(0,0,0,0.04)] relative z-10">
              <span class="text-2xl font-bold text-primary">{item.step}</span>
            </div>
            <div>
              <h3 class="text-xl font-bold text-text-main mb-3">{item.title}</h3>
              <p class="text-text-muted leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
        
      </div>
    </div>
  </div>
</section>

<script>
  // Simple scroll progress for the process line
  const section = document.querySelector('#process-line')?.closest('section');
  const progressDesktop = document.getElementById('process-progress');
  const progressMobile = document.getElementById('process-progress-mobile');

  if (section && (progressDesktop || progressMobile)) {
    window.addEventListener('scroll', () => {
      const rect = section.getBoundingClientRect();
      const viewHeight = window.innerHeight;
      
      // Calculate how far we scrolled through the section
      if (rect.top < viewHeight && rect.bottom > 0) {
        let percentage = (viewHeight - rect.top) / (viewHeight + rect.height * 0.5);
        percentage = Math.max(0, Math.min(1, percentage));
        
        if (progressDesktop) progressDesktop.style.transform = `scaleX(${percentage})`;
        if (progressMobile) progressMobile.style.transform = `scaleY(${percentage})`;
      }
    });
  }
</script>
