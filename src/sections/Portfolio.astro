---

<section class="py-24 md:py-32 bg-bg-sec overflow-hidden">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16 reveal">
      <div class="max-w-[600px]">
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-text-main mb-6">Trabajos Recientes</h2>
        <p class="text-xl text-text-muted">No confíes en lo que decimos, confía en lo que construimos.</p>
      </div>
      <a href="/portfolio" class="inline-flex items-center gap-2 font-medium text-primary hover:text-primary/80 transition-colors">
        Ver todo el portfolio
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    <div class="grid md:grid-cols-2 gap-8 md:gap-12">
      
      <!-- Portfolio Item 1 -->
      <a href="/portfolio/clinica-dental" class="group reveal block">
        <div class="w-full aspect-[4/3] rounded-[24px] overflow-hidden bg-bg-base border border-border mb-6 relative">
          <!-- Placeholder Image - In real app use <Image> from astro:assets -->
          <div class="absolute inset-0 bg-[#F3F4F6] transition-transform duration-500 ease-out group-hover:scale-[1.03]">
            <div class="w-full h-full flex flex-col">
              <div class="h-10 bg-white border-b border-border flex items-center px-4 gap-2">
                <div class="w-2.5 h-2.5 rounded-full bg-[#E5E7EB]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#E5E7EB]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#E5E7EB]"></div>
              </div>
              <div class="flex-grow flex items-center justify-center text-text-muted">Imagen del Proyecto 1</div>
            </div>
          </div>
        </div>
        <div class="flex justify-between items-start">
          <div>
            <h3 class="text-2xl font-bold text-text-main mb-2">Clínica Dental Sonrisa</h3>
            <p class="text-text-muted">Web Corporativa & Sistema de Reservas</p>
          </div>
          <div class="text-right">
            <span class="text-sm font-medium bg-bg-base border border-border px-3 py-1 rounded-full text-text-main block mb-2">Salud</span>
            <span class="text-sm text-text-muted">3 semanas</span>
          </div>
        </div>
      </a>

      <!-- Portfolio Item 2 -->
      <a href="/portfolio/restaurante-la-mar" class="group reveal block" style="transition-delay: 100ms;">
        <div class="w-full aspect-[4/3] rounded-[24px] overflow-hidden bg-bg-base border border-border mb-6 relative">
           <div class="absolute inset-0 bg-[#F3F4F6] transition-transform duration-500 ease-out group-hover:scale-[1.03]">
            <div class="w-full h-full flex flex-col">
              <div class="h-10 bg-white border-b border-border flex items-center px-4 gap-2">
                <div class="w-2.5 h-2.5 rounded-full bg-[#E5E7EB]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#E5E7EB]"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-[#E5E7EB]"></div>
              </div>
              <div class="flex-grow flex items-center justify-center text-text-muted">Imagen del Proyecto 2</div>
            </div>
          </div>
        </div>
        <div class="flex justify-between items-start">
          <div>
            <h3 class="text-2xl font-bold text-text-main mb-2">La Mar Restaurante</h3>
            <p class="text-text-muted">Menú Digital QR & Web Moderna</p>
          </div>
          <div class="text-right">
            <span class="text-sm font-medium bg-bg-base border border-border px-3 py-1 rounded-full text-text-main block mb-2">Gastronomía</span>
            <span class="text-sm text-text-muted">2 semanas</span>
          </div>
        </div>
      </a>

    </div>
  </div>
</section>
