---
import PrimaryButton from '../components/ui/PrimaryButton.astro';
---

<section class="py-32 bg-primary text-white text-center">
  <div class="max-w-[800px] mx-auto px-6 reveal">
    <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-8">¿Listo para digitalizar tu negocio?</h2>
    <p class="text-xl text-white/80 mb-10 max-w-[600px] mx-auto">
      Deja de perder clientes por no tener una presencia online que transmita la calidad de tu trabajo.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <PrimaryButton href="/contacto" class="bg-white text-primary hover:bg-white hover:scale-105 hover:-translate-y-1 hover:shadow-xl w-full sm:w-auto text-lg py-4 px-8">Solicitar presupuesto</PrimaryButton>
      <a href="https://wa.me/123456789" class="text-white/90 hover:text-white underline underline-offset-4 mt-4 sm:mt-0 sm:ml-4 font-medium transition-colors">o escríbenos por WhatsApp</a>
    </div>
  </div>
</section>
