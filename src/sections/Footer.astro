<footer class="bg-bg-sec border-t border-border pt-20 pb-10">
  <div class="max-w-[1280px] mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 mb-16">
      
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-6 group">
          <div class="w-8 h-8 rounded-lg bg-primary text-white flex items-center justify-center font-bold text-lg">A</div>
          <span class="font-bold text-xl tracking-tight text-text-main">The Ascend<span class="text-primary">.</span></span>
        </a>
        <p class="text-text-muted text-sm mb-6">Sistemas digitales para pequeños negocios que quieren crecer.</p>
      </div>

      <div>
        <h4 class="font-bold text-text-main mb-6" data-i18n-key="footer.company">Empresa</h4>
        <ul class="space-y-4">
          <li><a href="/soluciones" class="text-text-muted hover:text-text-main transition-colors text-sm">Soluciones</a></li>
          <li><a href="/planes" class="text-text-muted hover:text-text-main transition-colors text-sm">Planes</a></li>
          <li><a href="/portfolio" class="text-text-muted hover:text-text-main transition-colors text-sm">Portfolio</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-bold text-text-main mb-6" data-i18n-key="footer.help">Ayuda</h4>
        <ul class="space-y-4">
          <li><a href="/contacto" class="text-text-muted hover:text-text-main transition-colors text-sm">Contacto</a></li>
          <li><a href="/#faq" class="text-text-muted hover:text-text-main transition-colors text-sm">FAQ</a></li>
          <li><a href="https://wa.me/123456789" class="text-text-muted hover:text-text-main transition-colors text-sm">Soporte WhatsApp</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-bold text-text-main mb-6" data-i18n-key="footer.legal">Legal</h4>
        <ul class="space-y-4">
          <li><a href="/privacidad" class="text-text-muted hover:text-text-main transition-colors text-sm">Privacidad</a></li>
          <li><a href="/terminos" class="text-text-muted hover:text-text-main transition-colors text-sm">Términos</a></li>
          <li><a href="/cookies" class="text-text-muted hover:text-text-main transition-colors text-sm">Cookies</a></li>
        </ul>
      </div>

    </div>

    <div class="border-t border-border pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-text-muted">© {new Date().getFullYear()} The Ascend OS. Todos los derechos reservados.</p>
      
      <!-- Market Indication Footer -->
      <div class="flex items-center gap-2 text-sm text-text-muted">
        <span>Diseñado en</span>
        <svg class="w-4 h-4 text-text-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="m19 9-7 7-7-7"/></svg>
      </div>
    </div>
  </div>
</footer>
