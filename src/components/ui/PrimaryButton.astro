---
export interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  id?: string;
  ['data-i18n-key']?: string;
}

const { href, type = 'button', class: className, id, 'data-i18n-key': i18nKey } = Astro.props;

const Element = href ? 'a' : 'button';
const elementProps = href ? { href, id, 'data-i18n-key': i18nKey } : { type, id, 'data-i18n-key': i18nKey };
---

<Element 
  {...elementProps}
  class:list={[
    "inline-flex items-center justify-center px-6 py-3",
    "bg-primary text-white font-medium text-sm sm:text-base",
    "rounded-[14px]",
    "transition-all duration-300 ease-out",
    "hover:scale-[1.02] hover:-translate-y-[2px] hover:shadow-[0_8px_20px_rgba(37,99,235,0.15)]",
    "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2",
    className
  ]}
>
  <slot />
</Element>
