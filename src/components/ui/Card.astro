---
export interface Props {
  class?: string;
  hoverEffect?: boolean;
}

const { class: className, hoverEffect = false } = Astro.props;
---

<div class:list={[
  "bg-bg-base border border-border rounded-[22px]",
  "p-6 sm:p-8",
  "transition-all duration-300 ease-out",
  hoverEffect && "hover:-translate-y-[8px] hover:shadow-[0_12px_24px_rgba(0,0,0,0.03)]",
  className
]}>
  <slot />
</div>
