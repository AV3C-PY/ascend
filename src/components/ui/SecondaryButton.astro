---
export interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  id?: string;
  ['data-i18n-key']?: string;
}

const { href, type = 'button', class: className, id, 'data-i18n-key': i18nKey } = Astro.props;

const Element = href ? 'a' : 'button';
const elementProps = href ? { href, id, 'data-i18n-key': i18nKey } : { type, id, 'data-i18n-key': i18nKey };
---

<Element 
  {...elementProps}
  class:list={[
    "inline-flex items-center justify-center px-6 py-3",
    "bg-bg-base text-text-main font-medium text-sm sm:text-base",
    "border border-border",
    "rounded-[14px]",
    "transition-colors duration-300 ease-out",
    "hover:bg-[#F3F4F6]",
    "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-border focus-visible:ring-offset-2",
    className
  ]}
>
  <slot />
</Element>
