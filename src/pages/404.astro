---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/Header.astro';
import Footer from '../sections/Footer.astro';
import PrimaryButton from '../components/ui/PrimaryButton.astro';
---

<BaseLayout title="Página no encontrada">
  <Header />

  <main class="flex-grow flex items-center justify-center min-h-[70vh] bg-bg-base py-20">
    <div class="max-w-[600px] mx-auto px-6 text-center reveal">
      <div class="text-primary font-bold text-6xl md:text-8xl mb-6">404</div>
      <h1 class="text-2xl md:text-4xl font-bold tracking-tight text-text-main mb-6">
        No encontramos esta página, pero sí podemos ayudarte a encontrar la solución adecuada.
      </h1>
      <p class="text-lg text-text-muted mb-10">
        La ruta que has introducido no existe o ha sido movida.
      </p>
      <PrimaryButton href="/">Volver al inicio</PrimaryButton>
    </div>
  </main>

  <Footer />
</BaseLayout>
