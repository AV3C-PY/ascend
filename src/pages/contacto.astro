---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/Header.astro';
import Footer from '../sections/Footer.astro';
import Input from '../components/ui/Input.astro';
import PrimaryButton from '../components/ui/PrimaryButton.astro';
---

<BaseLayout title="Contacto" description="Solicita un presupuesto para digitalizar tu negocio.">
  <Header />

  <main class="flex-grow pt-32 pb-24 bg-bg-base">
    <div class="max-w-[1280px] mx-auto px-6 grid md:grid-cols-2 gap-16 lg:gap-24">
      
      <!-- Left: Contact Form -->
      <div>
        <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-text-main mb-6">Empecemos.</h1>
        <p class="text-lg text-text-muted mb-10">Cuéntanos sobre tu negocio y qué necesitas. Te responderemos en menos de 24 horas con un plan de acción.</p>
        
        <form id="contact-form" class="space-y-6" novalidate>
          <div class="grid grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="name" class="block text-sm font-medium text-text-main">Nombre *</label>
              <Input type="text" id="name" name="name" required />
              <p class="text-error text-xs font-medium hidden" id="err-name">Este campo es obligatorio.</p>
            </div>
            <div class="space-y-2">
              <label for="company" class="block text-sm font-medium text-text-main">Empresa *</label>
              <Input type="text" id="company" name="company" required />
              <p class="text-error text-xs font-medium hidden" id="err-company">Este campo es obligatorio.</p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="sector" class="block text-sm font-medium text-text-main">Sector</label>
              <Input type="text" id="sector" name="sector" />
            </div>
            <div class="space-y-2">
              <label for="country" class="block text-sm font-medium text-text-main">País *</label>
              <Input type="text" id="country" name="country" required />
              <p class="text-error text-xs font-medium hidden" id="err-country">Este campo es obligatorio.</p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="service" class="block text-sm font-medium text-text-main">Servicio de interés</label>
              <select id="service" name="service" class="w-full px-4 py-3 bg-bg-base text-text-main border border-border rounded-[16px] transition-all duration-300 ease-out focus-visible:outline-none focus-visible:border-primary focus-visible:ring-1 focus-visible:ring-primary hover:border-text-muted/30">
                <option value="web">Desarrollo Web / Landing Page</option>
                <option value="ecommerce">Tienda Online (Shopify)</option>
                <option value="whatsapp">Automatización WhatsApp</option>
                <option value="branding">Branding & Diseño</option>
                <option value="other">Otro</option>
              </select>
            </div>
            <div class="space-y-2">
              <label for="budget" class="block text-sm font-medium text-text-main">Presupuesto estimado *</label>
              <select id="budget" name="budget" required class="w-full px-4 py-3 bg-bg-base text-text-main border border-border rounded-[16px] transition-all duration-300 ease-out focus-visible:outline-none focus-visible:border-primary focus-visible:ring-1 focus-visible:ring-primary hover:border-text-muted/30">
                <option value="" disabled selected>Seleccionar...</option>
                <option value="<1000">Menos de 1.000€</option>
                <option value="1000-3000">1.000€ - 3.000€</option>
                <option value="3000-5000">3.000€ - 5.000€</option>
                <option value=">5000">Más de 5.000€</option>
              </select>
              <p class="text-error text-xs font-medium hidden" id="err-budget">Selecciona un presupuesto.</p>
            </div>
          </div>

          <div class="space-y-2">
            <label for="message" class="block text-sm font-medium text-text-main">Mensaje *</label>
            <Input textarea id="message" name="message" rows={5} required placeholder="¿Cuáles son los principales desafíos de tu negocio hoy?" />
            <p class="text-error text-xs font-medium hidden" id="err-message">Por favor, cuéntanos un poco sobre tu proyecto.</p>
          </div>

          <PrimaryButton type="submit" class="w-full py-4 text-lg" id="submit-btn">Enviar Solicitud</PrimaryButton>
          
          <div id="form-success" class="hidden p-4 rounded-[14px] bg-success/10 text-success font-medium text-center">
            ¡Mensaje enviado correctamente! Nos pondremos en contacto contigo pronto.
          </div>
          <div id="form-error" class="hidden p-4 rounded-[14px] bg-error/10 text-error font-medium text-center">
            Hubo un error al enviar el mensaje. Por favor, inténtalo de nuevo.
          </div>
        </form>
      </div>

      <!-- Right: Direct Contact Info -->
      <div class="flex flex-col justify-center lg:pl-12">
        <div class="bg-bg-sec rounded-[24px] p-8 md:p-12 border border-border">
          <h2 class="text-2xl font-bold text-text-main mb-8">Contacto directo</h2>
          
          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-[14px] bg-primary/10 text-primary flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <h4 class="text-sm font-medium text-text-muted mb-1">WhatsApp / Teléfono</h4>
                <a href="https://wa.me/123456789" class="text-lg font-bold text-text-main hover:text-primary transition-colors">+34 600 000 000</a>
                <p class="text-sm text-text-muted mt-1">Lunes a Viernes, 9:00 - 18:00 (CET)</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-[14px] bg-primary/10 text-primary flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <h4 class="text-sm font-medium text-text-muted mb-1">Correo Electrónico</h4>
                <a href="mailto:hola@theascend.os" class="text-lg font-bold text-text-main hover:text-primary transition-colors">hola@theascend.os</a>
              </div>
            </div>
          </div>
        </div>
      </div>
      
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const msgSuccess = document.getElementById('form-success');
  const msgError = document.getElementById('form-error');

  const showError = (id: string, show: boolean, inputId: string) => {
    const errEl = document.getElementById(`err-${id}`);
    const inputEl = document.getElementById(inputId);
    if (show) {
      errEl?.classList.remove('hidden');
      inputEl?.classList.add('border-error', 'focus-visible:ring-error', 'focus-visible:border-error');
      inputEl?.classList.remove('border-border', 'focus-visible:ring-primary', 'focus-visible:border-primary');
    } else {
      errEl?.classList.add('hidden');
      inputEl?.classList.remove('border-error', 'focus-visible:ring-error', 'focus-visible:border-error');
      inputEl?.classList.add('border-border', 'focus-visible:ring-primary', 'focus-visible:border-primary');
    }
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Reset state
    msgSuccess?.classList.add('hidden');
    msgError?.classList.add('hidden');
    let isValid = true;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    // Basic Validation
    const requiredFields = ['name', 'company', 'country', 'budget', 'message'];
    requiredFields.forEach(field => {
      const val = data[field] as string;
      if (!val || val.trim() === '') {
        isValid = false;
        showError(field, true, field);
      } else {
        showError(field, false, field);
      }
    });

    if (!isValid) return;

    // Loading state
    btn.disabled = true;
    const originalText = btn.textContent;
    btn.textContent = 'Enviando...';

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (response.ok) {
        msgSuccess?.classList.remove('hidden');
        form.reset();
      } else {
        throw new Error('API Error');
      }
    } catch (error) {
      console.error(error);
      msgError?.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      if (originalText) btn.textContent = originalText;
    }
  });

  // Remove error on input change
  form?.querySelectorAll('input, select, textarea').forEach(input => {
    input.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      showError(target.name, false, target.id);
    });
  });
</script>
